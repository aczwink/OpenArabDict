{    
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Multi sense verb definition",
    "description": "JSON Schema for verbs with multiple senses definitions",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "form": {
            "oneOf": [
                {
                    "type": "integer",
                    "minimum": 2,
                    "maximum": 10
                },
                {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "stem": {
                            "type": "integer",
                            "enum": [2, 3, 4, 5, 6, 7, 8, 9, 10]
                        },
                        "type": {
                            "type": "string",
                            "enum": ["irregular", "sound"]
                        },
                        "valency": {
                            "type": "string",
                            "enum": ["transitive"]
                        }
                    },
                    "required": ["stem"]
                },
                {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "stative": {
                            "type": "boolean",
                            "const": true
                        },
                        "stem": {
                            "type": "integer",
                            "const": 1
                        },
                        "valency": {
                            "type": "string",
                            "enum": ["transitive"]
                        },
                        "variants": {
                            "type": "array",
                            "items": {
                                "oneOf": [
                                    {
                                        "$ref": "../verbs/lb_variant.json"
                                    },
                                    {
                                        "$ref": "../verbs/msa_variant.json"
                                    }
                                ]
                            }
                        }
                    },
                    "required": ["stem", "variants"]
                }
            ]
        },
        "senses": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "derived": {
                        "type": "array",
                        "items": {
                            "$ref": "./OpenArabDictWord_verbderived.json"
                        }
                    },
                    "translations": {
                        "type": "array",
                        "items": {
                            "oneOf": [
                                {
                                    "$ref": "../translations/OpenArabDictHW4TranslationEntry.json"
                                }
                            ]
                        }
                    }
                },
                "required": ["translations"]
            }
        },
        "type": {
            "const": "verb"
        }
    },
    "required": ["form", "senses", "type"]
}