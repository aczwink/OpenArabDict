{    
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Multi sense definition",
    "description": "JSON Schema for Lexeme with multiple senses definitions",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "derivation": {
            "type": "string",
            "enum": [
                "verbal-noun"
            ]
        },
        "text": {
            "type": "string"
        },
        "senses": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "derived": {
                        "type": "array",
                        "items": {
                            "$ref": "./OpenArabDictWord_derived.json"
                        }
                    },
                    "translations": {
                        "type": "array",
                        "items": {
                            "oneOf": [
                                {
                                    "$ref": "../translations/OpenArabDictHW4TranslationEntry.json"
                                }
                            ]
                        }
                    }
                },
                "required": ["translations"]
            }
        }
    },
    "required": ["derivation", "text", "senses"]
}