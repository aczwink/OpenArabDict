{    
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "OpenArabDict noun definition",
    "description": "JSON Schema for OpenArabDict noun definitions",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "derived": {
            "type": "array",
            "items": {
                "oneOf": [
                    {
                        "$ref": "./OpenArabDictWord_derived.json"
                    },
                    {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                            "derivation": {
                                "type": "string",
                                "enum": [
                                    "plural"
                                ]
                            },
                            "ref": {
                                "type": "string"
                            }
                        },
                        "required": ["derivation", "ref"]
                    }
                ]
            }
        },
        "derived-from": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "derivation": {
                        "type": "string",
                        "enum": ["composed-of"]
                    },
                    "ref": {
                        "type": "string"
                    }
                },
                "required": ["derivation", "ref"]
            }
        },
        "gender": {
            "type": "string",
            "enum": [
                "female",
                "male",
                "male-or-female"
            ]
        },
        "text": {
            "type": "string"
        },
        "translations": {
            "type": "array",
            "items": {
                "oneOf": [
                    {
                        "$ref": "../translations/OpenArabDictFreeTextTranslationEntry.json"
                    },
                    {
                        "$ref": "../translations/OpenArabDictHW4TranslationEntry.json"
                    }
                ]
            }
        },
        "type": {
            "const": "noun"
        }
    },
    "required": ["text", "type"]
}