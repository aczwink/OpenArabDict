{    
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Multi POS definition",
    "description": "JSON Schema for Lexeme with multiple Parts of Speeches definitions",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "derivation": {
            "type": "string",
            "enum": [
                "passive-participle"
            ]
        },
        "pos": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": ["adjective", "noun"]
                    },
                    "translations": {
                        "type": "array",
                        "items": {
                            "oneOf": [
                                {
                                    "$ref": "../translations/OpenArabDictHW4TranslationEntry.json"
                                }
                            ]
                        }
                    }
                },
                "required": ["type", "translations"]
            }
        }
    },
    "required": ["derivation", "pos"]
}